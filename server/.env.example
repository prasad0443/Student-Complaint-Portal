PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/student_complaint_portal
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# Set to true when behind Nginx / load balancer
TRUST_PROXY=false

# Rate limiting (optional)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
RATE_LIMIT_AUTH_MAX=20

# File storage: local (default) or s3
STORAGE_PROVIDER=local
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_FORCE_PATH_STYLE=false

# Socket.io horizontal scaling (optional)
# REDIS_URL=redis://127.0.0.1:6379

# Optional: email (leave empty to log only in console)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="SCP Portal <noreply@example.com>"
